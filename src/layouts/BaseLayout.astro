---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Hướng dẫn thủ tục đăng ký xe – Công an phường Ngũ Hành Sơn",
  description = "Công an phường Ngũ Hành Sơn – TP. Đà Nẵng hướng dẫn các thủ tục đăng ký xe trực tuyến: bấm biển số, sang tên xe, cấp lại giấy đăng ký, khai báo xe đã bán và sử dụng ứng dụng VNETRAFFIC trên Cổng Dịch vụ công Bộ Công An.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const siteUrl = new URL(base, Astro.site).href;
const ogImage = new URL('imgs/banner.png', siteUrl).href;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- SEO -->
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:title" content="Hướng dẫn đăng ký xe – Công an phường Ngũ Hành Sơn" />
    <meta
      property="og:description"
      content="Hướng dẫn các thủ tục đăng ký xe trực tuyến: bấm biển số tại nhà, sang tên xe, cấp lại giấy đăng ký, khai báo xe đã bán/cho tặng và sử dụng VNETRAFFIC. Xem video hướng dẫn chi tiết từ Công an phường Ngũ Hành Sơn, TP. Đà Nẵng."
    />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Hướng dẫn đăng ký xe – Công an phường Ngũ Hành Sơn" />
    <meta property="og:site_name" content="Công an phường Ngũ Hành Sơn – TP. Đà Nẵng" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Hướng dẫn đăng ký xe – Công an phường Ngũ Hành Sơn" />
    <meta
      name="twitter:description"
      content="Hướng dẫn các thủ tục đăng ký xe trực tuyến: bấm biển số tại nhà, sang tên xe, cấp lại giấy đăng ký, khai báo xe đã bán/cho tặng và sử dụng VNETRAFFIC. Xem video hướng dẫn chi tiết từ Công an phường Ngũ Hành Sơn, TP. Đà Nẵng."
    />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}apple-touch-icon.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}favicon-16x16.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-gray-50 text-gray-800">
    <slot />
  </body>
</html>
